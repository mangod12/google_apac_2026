# Server
PORT=8080

# Database
DATABASE_URL=postgresql+asyncpg://taskforge:taskforge@localhost:5432/taskforge

# Gemini (pick ONE auth mode)
# Option A: Gemini Developer API key
GEMINI_API_KEY=your-api-key-here

# Option B: Vertex AI (comment out API key above)
# VERTEX_AI_PROJECT=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1

# Model
GEMINI_MODEL=gemini-2.5-flash

# Agent Settings
MAX_AGENT_ITERATIONS=10
LOG_LEVEL=INFO

# CORS — restrict to your frontend domain(s) in production
# Example: CORS_ORIGINS=["https://your-app.run.app","https://your-domain.com"]
CORS_ORIGINS=["*"]
